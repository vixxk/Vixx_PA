# ==========================================
# Personal Work OS - Root Gitignore
# ==========================================

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~
.project
.classpath
.settings/

# Node / Frontend
node_modules/
/frontend/node_modules/
/frontend/dist/
/frontend/dist-ssr/
/frontend/out/
*.local

# Python / Backend
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python Virtual Environments
.venv/
venv/
ENV/
env/
/backend/.venv/
/backend/venv/
/backend/env/

# Environment and Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
/backend/.env

# Allow env.example files
!.env.example
!backend/.env.example

# Logs
*.log
/backend/notification_logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Uploads and Database
/uploads/
/backend/uploads/
*.db
*.sqlite3

# Temporary / Miscellaneous
Vixx_PA/
temp/
tmp/
