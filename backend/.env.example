# ==========================================
# Personal Work OS - Configuration
# ==========================================

# --- API Server Configurations ---
PORT=8000
HOST=0.0.0.0
DEBUG=True

# --- Database Configuration ---
# Format: postgresql+asyncpg://<username>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql+asyncpg://vixx:password@localhost:5432/work_os

# --- Authentication Settings ---
JWT_SECRET_KEY=generate_a_secure_jwt_secret_key_here_using_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- LLM API Keys (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google integration (Sheets, Calendar) ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- GitHub Integration ---
GITHUB_ACCESS_TOKEN=your_github_personal_access_token_here
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# --- CORS Settings ---
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# --- Meta WhatsApp Cloud API ---
META_WHATSAPP_ACCESS_TOKEN=your_meta_whatsapp_access_token_here
META_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
META_WHATSAPP_VERSION=v20.0
USER_WHATSAPP_NUMBER=+91XXXXXXXXXX
META_WHATSAPP_TEMPLATE_NAME=your_whatsapp_template_name_here
META_WHATSAPP_TEMPLATE_LANG=en_US

